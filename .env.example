# Variables de entorno para `docker compose`. Copia este fichero a `.env` y
# rellénalo con tus valores reales. `.env` está ignorado por git (ver
# `.gitignore`); no lo subas al repositorio porque contiene credenciales.

# --- MySQL --------------------------------------------------------------
# Solo se usan en el PRIMER arranque (cuando el volumen `mysql_data` está
# vacío). MySQL los lee para crear la BD y el usuario aplicativo. En
# arranques posteriores se ignoran.
MYSQL_ROOT_PASSWORD=cambia_este_password_de_root
MYSQL_USER=guzmanges
MYSQL_PASSWORD=cambia_este_password_de_usuario
MYSQL_DATABASE=guzmanges

# (Opcional) Solo aplica si activas `docker-compose.override.yml` para
# exponer MySQL al host. Por defecto, MySQL es accesible solo desde la API.
# MYSQL_HOST_PORT=3306

# --- JWT ----------------------------------------------------------------
# Secreto para firmar los tokens. DEBE tener al menos 64 caracteres y ser
# aleatorio (no usar palabras de diccionario). Para generar uno:
#   - Linux/macOS: `openssl rand -base64 64`
#   - PowerShell:  `[Convert]::ToBase64String((1..64 | %{Get-Random -Max 256}))`
JWT_SECRET=CAMBIA_ESTE_SECRETO_POR_UNHA_CADEA_LONGA_E_ALEATORIA_DE_ALOMENOS_64_CARACTERES_PARA_PRODUCION

# --- Odoo ---------------------------------------------------------------
# URL y credenciales de la instancia de Odoo con la que se sincroniza la
# API. El usuario tiene que poder leer/escribir res.partner, product.product,
# sale.order y los catálogos de pagos.
ODOO_URL=https://tu-odoo.example.com
ODOO_DB=nombre_de_la_bd_odoo
ODOO_USER=usuario@example.com
ODOO_APIKEY=tu_api_key_de_odoo
ODOO_LANG=es_ES
ODOO_SYNC_ENABLED=true

# --- Otros --------------------------------------------------------------
# Palabra clave (sin distinguir mayúsculas/minúsculas) que el backend busca
# en el nombre de la posición fiscal del cliente para decidir si aplica
# recargo de equivalencia.
POSICION_FISCAL_RECARGO_KEYWORD=recargo

# Orígenes permitidos por CORS. Lista separada por comas; admite comodines.
# En producción, sustituir por el dominio real del frontend.
CORS_ALLOWED_ORIGINS=http://localhost:*

# Mostrar las consultas SQL en los logs (útil para depurar; desactiva en
# producción para no llenar el log).
JPA_SHOW_SQL=false

# Puerto del host al que se mapea la API. Cambiar si el 8080 ya está en uso.
API_HOST_PORT=8080

# Opciones JVM extra (memoria, GC, etc.). Vacío por defecto.
JAVA_OPTS=
